{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "md-condesa-wa-agent",
  "main": "src/index.ts",
  "compatibility_date": "2024-11-27",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "wa-agent-db",
      "database_id": "c57b17de-9e0c-4a48-adc7-7cb791372cdc"
    }
  ],
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "vars": {
    "SLACK_CHANNEL_ID": "C0BFKQ6AU9F",
    "AIRTABLE_BASE_ID": "appcX38TBVltyxHR6",
    "AIRTABLE_TRIALS_TABLE": "Leads",
    "TRAINING_WHEELS": "1",
    "HUMAN_SNOOZE_HOURS": "8"
  },
  // Text modules: the compiled KB (*.md, see src/kb.ts) and the admin SPA
  // (src/ui/admin.html, imported by routes/admin-ui.ts) are inlined as strings.
  "rules": [
    {
      "type": "Text",
      "globs": ["**/*.md", "**/*.html"],
      "fallthrough": false
    }
  ]
}
