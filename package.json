{
  "name": "md-condesa-wa-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "node tools/compile-kb.mjs",
    "deploy": "npm run build && wrangler deploy",
    "chat": "tsc --outDir .chatdist --rootDir src --noEmit false --declaration false && echo '{\"type\":\"module\"}' > .chatdist/package.json && node tools/chat-local.mjs",
    "test": "tsc -p tsconfig.test.json && node --test \"dist-test/test/**/*.test.js\""
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.7.2",
    "wrangler": "^3.90.0"
  }
}
